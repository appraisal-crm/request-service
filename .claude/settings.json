{
  "permissions": {
    "allow": [
      "Bash(go build ./...)",
      "Bash(go test ./...)",
      "Bash(go test -run * ./...)",
      "Bash(go vet ./...)",
      "Bash(golangci-lint run *)",
      "Bash(swag init *)",
      "Bash(migrate *)",
      "Bash(docker compose *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(ls *)",
      "Bash(find * -name *.go)",
      "Bash(grep -r * services/)",
      "Bash(npm run * --prefix frontend/*)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(rm -rf *)",
      "Bash(kubectl delete *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // .tool_input.path // empty' 2>/dev/null); if echo \"$FILE\" | grep -q '\\.go$'; then gofmt -l \"$FILE\" 2>&1; fi"
          }
        ]
      }
    ]
  }
}
